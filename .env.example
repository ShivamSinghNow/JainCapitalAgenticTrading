# ============================================
# JAIN CAPITAL TRADING SYSTEM - ENV TEMPLATE
# ============================================
# Copy this file to .env and fill in your actual API keys
# NEVER commit .env to git!

# --- Core LLM API Keys (REQUIRED) ---
OPENAI_API_KEY=sk-proj-YOUR_OPENAI_KEY_HERE
# Get your key from: https://platform.openai.com/api-keys

# Optional: Use alternative LLM provider
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_PROVIDER=openai

# --- Agent Configuration ---
AGENT_DEEP_MODEL=gpt-4o-mini      # Deep thinking model
AGENT_QUICK_MODEL=gpt-4o-mini     # Quick analysis model
AGENT_MAX_DEBATE=1                # Max debate rounds (1 = faster)

# --- Stock/Crypto Data (Optional) ---
FINNHUB_API_KEY=your_finnhub_key_here
# Get free key from: https://finnhub.io/register

# --- Binance Spot Testnet (Optional for live trading) ---
BINANCE_API_KEY=your_binance_testnet_key
BINANCE_API_SECRET=your_binance_testnet_secret
# Create testnet account: https://testnet.binance.vision/

# --- 3Commas Integration (Optional) ---
THREECOMMAS_API_KEY=your_3commas_key
THREECOMMAS_API_SECRET=your_3commas_secret
THREECOMMAS_ACCOUNT_ID=your_3commas_account_id
THREECOMMAS_PAPER=1

# --- Crypto Data APIs (All FREE, Optional but Recommended) ---

# CryptoPanic - Crypto news aggregation (3000 req/day)
CRYPTOPANIC_API_KEY=your_cryptopanic_key_here
# Sign up: https://cryptopanic.com/developers/api/

# CryptoCompare - Market data & social stats (100k calls/month)
CRYPTOCOMPARE_API_KEY=your_cryptocompare_key_here
# Sign up: https://min-api.cryptocompare.com

# Reddit API - Social sentiment (Unlimited, OAuth2)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
# Create app: https://www.reddit.com/prefs/apps

# GitHub API - Track crypto project development (5000 req/hour)
GITHUB_TOKEN=ghp_your_github_token_here
# Create token: https://github.com/settings/tokens

# Etherscan API - Ethereum on-chain data (5 calls/second)
ETHERSCAN_API_KEY=your_etherscan_key_here
# Get key: https://etherscan.io/myapikey

# ============================================
# SECURITY NOTES:
# - Keep this file private and secure
# - Never commit .env to version control
# - Rotate keys if accidentally exposed
# - Use read-only or testnet keys when possible
# ============================================
